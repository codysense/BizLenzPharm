enum MemoStatus {
  OPEN
  CLOSED
  CANCELLED
  REVERSED
}

enum memoCategory {
  SALES_RETURN
  PURCHASE_RETURN
  FINANCIAL
}

model Memo {
  id     String   @id @default(cuid())
  memoNo String   @unique
  date   DateTime

  module   MemoModule // SALES | PURCHASES
  memoType MemoType // CREDIT | DEBIT
  category memoCategory @default(FINANCIAL)

  amount    Decimal
  remaining Decimal
  status    MemoStatus @default(OPEN) // OPEN | APPLIED | REVERSED

  description String?

  //  Source documents
  saleId     String?
  purchaseId String?

  sale     Sale?     @relation(fields: [saleId], references: [id])
  purchase Purchase? @relation(fields: [purchaseId], references: [id])

  //  Parties (standalone memo)
  customerId String?
  vendorId   String?

  customer Customer? @relation(fields: [customerId], references: [id])
  vendor   Vendor?   @relation(fields: [vendorId], references: [id])

  //  Account (standalone memo)
  accountId String?
  account   ChartOfAccount? @relation(fields: [accountId], references: [id])

  //  Journal linkage
  journalId String?
  journal   Journal? @relation(fields: [journalId], references: [id])

  //  REVERSAL FIELDS (NEW)
  isReversal     Boolean @default(false)
  reversedFromId String?
  reversedFrom   Memo?   @relation("MemoReversal", fields: [reversedFromId], references: [id])
  reversals      Memo[]  @relation("MemoReversal")

  //  Optional audit enhancement
  reversalReason String?

  createdBy String
  createdAt DateTime @default(now())

  user User @relation(fields: [createdBy], references: [id])

  @@index([saleId])
  @@index([purchaseId])
  @@index([customerId])
  @@index([vendorId])
  @@index([reversedFromId]) // 🔥 important for reversal lookup
  @@map("memo")
}

