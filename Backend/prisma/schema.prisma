generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x", "native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  refreshToken String   @unique

  user User @relation(fields: [userId], references: [id])
}

model User {
  id                          String                   @id @default(cuid())
  email                       String                   @unique
  name                        String
  password                    String
  status                      String                   @default("ACTIVE")
  lastLoginAt                 DateTime?
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
  warehouseId                 String?
  InventoryTransfer           InventoryTransfer[]
  ApprovalAction              ApprovalAction[]
  ApprovalRequest             ApprovalRequest[]
  assetDisposals              AssetDisposal[]
  assetsCreated               Asset[]                  @relation("AssetCreatedBy")
  auditLogs                   AuditLog[]
  cashTransactionPostings     CashTransactionPosting[]
  cashTransactionsApproved    CashTransaction[]        @relation("CashTransactionApprover")
  cashTransactionsAuthorized  CashTransaction[]        @relation("CashTransactionAuthorizer")
  cashTransactionsPaid        CashTransaction[]        @relation("CashTransactionPayer")
  cashTransactionsPrepared    CashTransaction[]        @relation("CashTransactionPreparer")
  cashTransactionsUser        CashTransaction[]        @relation("CashTransactionUser")
  customerPaymentPostings     CustomerPaymentPosting[]
  customerPaymentsApproved    CustomerPayment[]        @relation("CustomerPaymentApprover")
  customerPaymentsAuthorized  CustomerPayment[]        @relation("CustomerPaymentAuthorizer")
  customerPaymentsPaid        CustomerPayment[]        @relation("CustomerPaymentPayer")
  customerPaymentsPrepared    CustomerPayment[]        @relation("CustomerPaymentPreparer")
  customerPaymentsUser        CustomerPayment[]        @relation("CustomerPaymentUser")
  inventoryLedger             InventoryLedger[]
  journals                    Journal[]
  Memo                        Memo[]
  posReturns                  PosReturn[]
  posSales                    PosSale[]
  posSessions                 PosSession[]
  purchasePayments            PurchasePayment[]
  PurchaseRefund              PurchaseRefund[]
  salesReceipts               SalesReceipt[]
  SalesRefund                 SalesRefund[]
  StockAdjustment             StockAdjustment[]
  SystemSetting               SystemSetting[]
  userRoles                   UserRole[]
  warehouse                   Warehouse?               @relation(fields: [warehouseId], references: [id])
  postedVendorPaymentPostings VendorPaymentPosting[]   @relation("VendorPaymentPostedBy")
  vendorPaymentPostingUsers   VendorPaymentPosting[]   @relation("VendorPaymentPostedUser")
  approvedVendorPayments      VendorPayment[]          @relation("VendorPaymentApprovedBy")
  authorizedVendorPayments    VendorPayment[]          @relation("VendorPaymentAuthorizedBy")
  paidVendorPayments          VendorPayment[]          @relation("VendorPaymentPaidBy")
  preparedVendorPayments      VendorPayment[]          @relation("VendorPaymentPreparedBy")
  vendorPayments              VendorPayment[]          @relation("VendorPaymentCreatedBy")

  // ───── Vendor / Customer creators ─────
  vendorsCreated        Vendor[]        @relation("VendorCreatedBy")
  customerGroupsCreated CustomerGroup[] @relation("CustomerGroupCreatedBy")
  customersCreated      Customer[]      @relation("CustomerCreatedBy")

  // ───── Sale stage actors ─────
  salesPrepared  Sale[] @relation("SalePreparer")
  salesDelivered Sale[] @relation("SaleDeliverer")
  salesInvoiced  Sale[] @relation("SaleInvoicer")
  salesPaid      Sale[] @relation("SalePayer")

  // ───── Purchase stage actors ─────
  purchasesPrepared Purchase[]     @relation("PurchasePreparer")
  purchasesReceived Purchase[]     @relation("PurchaseReceiver")
  purchasesInvoiced Purchase[]     @relation("PurchaseInvoicer")
  purchasesPaid     Purchase[]     @relation("PurchasePayer")
  refreshTokens     RefreshToken[]
  UserSession       UserSession[]

  openingStocks OpeningStock[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Role {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  ApprovalStep    ApprovalStep[]
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  name            String           @unique
  resource        String
  action          String
  description     String?
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Company {
  id           String   @id @default(cuid())
  name         String
  baseCurrency String   @default("NGN")
  timezone     String   @default("Africa/Lagos")
  address      String?
  phone        String?
  email        String?
  createdAt    DateTime @default(now())

  @@map("companies")
}

model Location {
  id         String      @id @default(cuid())
  code       String      @unique
  name       String
  address    String?
  city       String?
  state      String?
  country    String      @default("Nigeria")
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  assets     Asset[]
  warehouses Warehouse[]

  @@map("locations")
}

model Warehouse {
  id                String              @id @default(cuid())
  code              String              @unique
  name              String
  address           String?
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  locationId        String
  outgoingTransfers InventoryTransfer[] @relation("TransferFromWarehouse")
  incomingTransfers InventoryTransfer[] @relation("TransferToWarehouse")
  bins              Bin[]
  CashAccount       CashAccount[]
  inventoryBatches  InventoryBatch[]
  inventoryLedger   InventoryLedger[]
  posReturns        PosReturn[]
  posSales          PosSale[]
  posSessions       PosSession[]
  productionOrders  ProductionOrder[]
  StockAdjustment   StockAdjustment[]
  openingStocks OpeningStock[]
  users             User[]
  location          Location            @relation(fields: [locationId], references: [id])

  @@map("warehouses")
}

model Bin {
  id               String           @id @default(cuid())
  warehouseId      String
  code             String
  name             String?
  warehouse        Warehouse        @relation(fields: [warehouseId], references: [id])
  inventoryBatches InventoryBatch[]

  @@unique([warehouseId, code])
  @@map("bins")
}

model Item {
  id                    String                  @id @default(cuid())
  sku                   String                  @unique
  name                  String
  description           String?
  type                  ItemType
  uom                   String                  @default("EA")
  minimumStockLevel     Decimal?                @db.Decimal(15, 4)
  costingMethod         CostingMethod           @default(WEIGHTED_AVG)
  standardCost          Decimal?                @db.Decimal(15, 4)
  taxCode               String?
  isActive              Boolean                 @default(true)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  sellingPriceBulk      Decimal?                @db.Decimal(15, 4)
  sellingPriceOrdinary  Decimal?                @db.Decimal(15, 4)
  cartonQuantity        Decimal?                @db.Decimal(15, 4)
  InventoryTransferItem InventoryTransferItem[]
  priceList             ItemPriceList[]
  AdjustmentLines       AdjustmentLines[]
  bomLines              BomLine[]
  boms                  Bom[]
  inventoryBatches      InventoryBatch[]
  inventoryLedger       InventoryLedger[]
  posReturnLines        PosReturnLine[]
  posSaleLines          PosSaleLine[]
  productionOrders      ProductionOrder[]
  purchaseLines         PurchaseLine[]
  saleLines             SaleLine[]
  wipLedgers            WipLedger[]

  openingStockLines OpeningStockLine[]

  @@map("items")
}

model UOM {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@map("uoms")
}

model ItemPriceList {
  id            String  @id @default(cuid())
  itemId        String
  customerGroup String
  price         Decimal @db.Decimal(15, 4)
  item          Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, customerGroup])
}

model Bom {
  id               String            @id @default(cuid())
  itemId           String
  version          String            @default("1.0")
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  bomLines         BomLine[]
  item             Item              @relation(fields: [itemId], references: [id])
  productionOrders ProductionOrder[]

  @@unique([itemId, version])
  @@map("boms")
}

model BomLine {
  id              String  @id @default(cuid())
  bomId           String
  componentItemId String
  qtyPer          Decimal @db.Decimal(15, 4)
  scrapPercent    Decimal @default(0) @db.Decimal(5, 2)
  bom             Bom     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentItem   Item    @relation(fields: [componentItemId], references: [id])

  @@map("bom_lines")
}

model InventoryBatch {
  id              String            @id @default(cuid())
  itemId          String
  warehouseId     String
  binId           String?
  qtyOnHand       Decimal           @db.Decimal(15, 4)
  unitCost        Decimal           @db.Decimal(15, 4)
  receivedAt      DateTime
  bin             Bin?              @relation(fields: [binId], references: [id])
  item            Item              @relation(fields: [itemId], references: [id])
  warehouse       Warehouse         @relation(fields: [warehouseId], references: [id])
  inventoryLedger InventoryLedger[]

  @@map("inventory_batches")
}

model InventoryLedger {
  id             String          @id @default(cuid())
  itemId         String
  warehouseId    String
  refType        String
  refId          String
  direction      LedgerDirection
  qty            Decimal         @db.Decimal(15, 4)
  unitCost       Decimal         @db.Decimal(15, 4)
  value          Decimal         @db.Decimal(15, 4)
  runningQty     Decimal         @db.Decimal(15, 4)
  runningValue   Decimal         @db.Decimal(15, 4)
  runningAvgCost Decimal         @db.Decimal(15, 4)
  batchId        String?
  postedAt       DateTime        @default(now())
  userId         String?
  batch          InventoryBatch? @relation(fields: [batchId], references: [id])
  item           Item            @relation(fields: [itemId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id])

  @@map("inventory_ledger")
}

model InventoryTransfer {
  id              String                  @id @default(cuid())
  refId           String                  @unique
  fromWarehouseId String
  toWarehouseId   String
  createdById     String
  createdAt       DateTime                @default(now())
  createdBy       User                    @relation(fields: [createdById], references: [id])
  fromWarehouse   Warehouse               @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse               @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  items           InventoryTransferItem[]
}

model InventoryTransferItem {
  id         String            @id @default(cuid())
  transferId String
  itemId     String
  qty        Decimal
  unitCost   Decimal
  item       Item              @relation(fields: [itemId], references: [id])
  transfer   InventoryTransfer @relation(fields: [transferId], references: [id])
}

model ProductionOrder {
  id                String                @id @default(cuid())
  orderNo           String                @unique
  itemId            String
  qtyTarget         Decimal               @db.Decimal(15, 4)
  qtyProduced       Decimal               @default(0) @db.Decimal(15, 4)
  status            ProductionOrderStatus @default(PLANNED)
  warehouseId       String
  bomId             String?
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  approvalRequestId String?
  approvalStatus    String?               @default("APPROVED")
  approvedAt        DateTime?
  approvedBy        String?
  laborTimes        LaborTime[]
  bom               Bom?                  @relation(fields: [bomId], references: [id])
  item              Item                  @relation(fields: [itemId], references: [id])
  warehouse         Warehouse             @relation(fields: [warehouseId], references: [id])
  wipLedger         WipLedger[]

  @@map("production_orders")
}

