model WipLedger {
  id                String          @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id])
  //  Type of entry
  type              WipLedgerType
  //  Core values
  amount            Decimal         @db.Decimal(15, 4)
  qty               Decimal?        @db.Decimal(15, 4)
  unitCost          Decimal?        @db.Decimal(15, 4)
  //  Item tracking (important for material + FG)
  itemId            String?
  item              Item?           @relation(fields: [itemId], references: [id])
  //  Warehouse tracking (important for inventory reversal)
  warehouseId       String?
  //  Reference tracking (CRITICAL for reversals)
  refType           String? // e.g. PRODUCTION, REVERSAL
  refId             String? // productionOrderId or journalId
  //  Reversal tracking (VERY IMPORTANT)
  isReversal        Boolean         @default(false)
  reversedFromId    String?
  reversedFrom      WipLedger?      @relation("WipLedgerReversal", fields: [reversedFromId], references: [id])
  reversals         WipLedger[]     @relation("WipLedgerReversal")
  //  Extra info
  note              String?
  postedAt          DateTime        @default(now())
  createdBy         String? // userId (optional but recommended)

  @@index([productionOrderId])
  @@index([itemId])
  @@index([refType, refId])
  @@map("wip_ledger")
}

model LaborTime {
  id                String          @id @default(cuid())
  productionOrderId String
  hours             Decimal         @db.Decimal(8, 2)
  rate              Decimal         @db.Decimal(10, 2)
  amount            Decimal         @db.Decimal(15, 4)
  employeeName      String?
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id])

  @@map("labor_times")
}

model Vendor {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  address      String?
  phone        String?
  email        String?
  paymentTerms String?
  isActive     Boolean  @default(true)
  createdBy    String?
  createdAt    DateTime @default(now())

  assets             Asset[]
  Memo               Memo[]
  purchasePayments   PurchasePayment[]
  PurchaseRefund     PurchaseRefund[]
  purchases          Purchase[]
  vendorPaymentLines VendorPaymentLine[]
  vendorPayments     VendorPayment[]
  //relation
  createdByUser      User?               @relation("VendorCreatedBy", fields: [createdBy], references: [id])

  @@map("vendors")
}

model CustomerGroup {
  id            String     @id @default(cuid())
  name          String     @unique
  createdBy     String?
  createdAt     DateTime   @default(now())
  code          String?
  description   String?
  isActive      Boolean    @default(true)
  customers     Customer[]
  createdByUser User?      @relation("CustomerGroupCreatedBy", fields: [createdBy], references: [id])
}

model Customer {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  address          String?
  phone            String?
  email            String?
  creditLimit      Decimal?          @db.Decimal(15, 2)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  createdBy        String?
  customerGroupId  String?
  customerPayments CustomerPayment[]
  customerGroup    CustomerGroup?    @relation(fields: [customerGroupId], references: [id])
  createdByUser    User?             @relation("CustomerCreatedBy", fields: [createdBy], references: [id])
  Memo             Memo[]
  posReturns       PosReturn[]
  posSales         PosSale[]
  sales            Sale[]
  salesReceipts    SalesReceipt[]
  SalesRefund      SalesRefund[]

  @@map("customers")
}

model Purchase {
  id        String   @id @default(cuid())
  orderNo   String   @unique
  vendorId  String
  orderDate DateTime

  orderType PurchaseOrderType @default(INVENTORY)
  status    PurchaseStatus    @default(DRAFT)

  totalAmount   Decimal @db.Decimal(15, 2)
  amountPaid    Decimal @default(0) @db.Decimal(15, 2)
  balanceAmount Decimal @default(0) @db.Decimal(15, 2)

  notes String?

  //Stage tracking
  preparedAt DateTime?
  preparedBy String?

  receivedAt DateTime?
  receivedBy String?

  invoicedAt DateTime?
  invoicedBy String?

  paidAt DateTime?
  paidBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assets             Asset[]
  purchaseLines      PurchaseLine[]
  purchasePayments   PurchasePayment[]
  PurchaseRefunds    PurchaseRefund[]
  vendorPaymentLines VendorPaymentLine[]

  vendor Vendor @relation(fields: [vendorId], references: [id])

  preparer User?  @relation("PurchasePreparer", fields: [preparedBy], references: [id])
  receiver User?  @relation("PurchaseReceiver", fields: [receivedBy], references: [id])
  invoicer User?  @relation("PurchaseInvoicer", fields: [invoicedBy], references: [id])
  payer    User?  @relation("PurchasePayer", fields: [paidBy], references: [id])
  memos    Memo[]

  @@map("purchases")
}

enum PurchaseOrderType {
  INVENTORY
  ASSET
}

model PurchaseLine {
  id         String   @id @default(cuid())
  purchaseId String
  itemId     String?
  assetName  String?
  qty        Decimal  @db.Decimal(15, 4)
  unitPrice  Decimal  @db.Decimal(15, 4)
  lineTotal  Decimal  @db.Decimal(15, 4)
  item       Item?    @relation(fields: [itemId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@map("purchase_lines")
}

model SaleLine {
  id        String  @id @default(cuid())
  saleId    String
  itemId    String
  qty       Decimal @db.Decimal(15, 4)
  unitPrice Decimal @db.Decimal(15, 4)
  lineTotal Decimal @db.Decimal(15, 4)
  item      Item    @relation(fields: [itemId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_lines")
}

model ChartOfAccount {
  id                          String                @id @default(cuid())
  code                        String                @unique
  name                        String
  accountType                 String
  parentId                    String?
  isActive                    Boolean               @default(true)
  createdAt                   DateTime              @default(now())
  description                 String?
  assetCategoriesAccumulated  AssetCategory[]       @relation("AssetCategoryAccumulatedDepreciationAccount")
  assetCategoriesAsset        AssetCategory[]       @relation("AssetCategoryAssetAccount")
  assetCategoriesDepreciation AssetCategory[]       @relation("AssetCategoryDepreciationAccount")
  cashAccounts                CashAccount[]         @relation("CashAccountGLAccount")
  cashTransactionLinesContra  CashTransactionLine[] @relation("CashTransactionLineContraAccount")
  cashTransactionLinesGL      CashTransactionLine[] @relation("CashTransactionLineGLAccount")
  parent                      ChartOfAccount?       @relation("AccountHierarchy", fields: [parentId], references: [id])
  children                    ChartOfAccount[]      @relation("AccountHierarchy")
  customerPaymentLines        CustomerPaymentLine[]
  journalLines                JournalLine[]
  Memo                        Memo[]
  StockAdjustment             StockAdjustment[]
  vendorPaymentLines          VendorPaymentLine[]

  @@map("chart_of_accounts")
}

model Journal {
  id                      String                   @id @default(cuid())
  journalNo               String                   @unique
  date                    DateTime
  memo                    String?
  postedBy                String
  postedAt                DateTime                 @default(now())
  assetDepreciation       AssetDepreciation[]
  assetDisposals          AssetDisposal[]
  cashTransactionPostings CashTransactionPosting[]
  customerPaymentPostings CustomerPaymentPosting[]
  journalLines            JournalLine[]
  postedByUser            User                     @relation(fields: [postedBy], references: [id])
  vendorPaymentPostings   VendorPaymentPosting[]
  memos                   Memo[]

  @@map("journals")
}

model JournalLine {
  id        String         @id @default(cuid())
  journalId String
  accountId String
  debit     Decimal        @default(0) @db.Decimal(15, 4)
  credit    Decimal        @default(0) @db.Decimal(15, 4)
  refType   String?
  refId     String?
  account   ChartOfAccount @relation(fields: [accountId], references: [id])
  journal   Journal        @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@map("journal_lines")
}

model Policy {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("policies")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entity     String
  entityId   String
  beforeJson Json?
  afterJson  Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_log")
}

model CashAccount {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  accountType      String
  accountNumber    String?
  bankName         String?
  balance          Decimal           @default(0) @db.Decimal(15, 2)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  glAccountId      String?
  chartOfAccountId String?
  warehouseId      String?
  chartOfAccount   ChartOfAccount?   @relation("CashAccountGLAccount", fields: [chartOfAccountId], references: [id])
  warehouse        Warehouse?        @relation(fields: [warehouseId], references: [id])
  cashTransactions CashTransaction[]
  customerPayments CustomerPayment[]
  posSales         PosSale[]
  posSessions      PosSession[]
  purchasePayments PurchasePayment[]
  PurchaseRefund   PurchaseRefund[]
  salesReceipts    SalesReceipt[]
  SalesRefund      SalesRefund[]
  vendorPayments   VendorPayment[]
  posSalePayments  PosSalePayment[]

  @@map("cash_accounts")
}

model CashTransaction {
  id               String                   @id @default(cuid())
  transactionNo    String                   @unique
  cashAccountId    String
  transactionType  String
  amount           Decimal                  @db.Decimal(15, 2)
  refType          String?
  refId            String?
  transactionDate  DateTime
  isReconciled     Boolean                  @default(false)
  reconciledAt     DateTime?
  userId           String
  createdAt        DateTime                 @default(now())
  reference        String?
  approvedAt       DateTime?
  approvedBy       String?
  authorizedAt     DateTime?
  authorizedBy     String?
  paidAt           DateTime?
  paidBy           String?
  preparedBy       String
  status           String                   @default("PREPARED")
  updatedAt        DateTime                 @updatedAt
  description      String?
  glAccountId      String?
  transactionLines CashTransactionLine[]
  postings         CashTransactionPosting[]
  approver         User?                    @relation("CashTransactionApprover", fields: [approvedBy], references: [id])
  authorizer       User?                    @relation("CashTransactionAuthorizer", fields: [authorizedBy], references: [id])
  cashAccount      CashAccount              @relation(fields: [cashAccountId], references: [id])
  payer            User?                    @relation("CashTransactionPayer", fields: [paidBy], references: [id])
  preparer         User                     @relation("CashTransactionPreparer", fields: [preparedBy], references: [id])
  user             User                     @relation("CashTransactionUser", fields: [userId], references: [id])

  @@map("cash_transactions")
}

model CashTransactionLine {
  id                String          @id @default(cuid())
  cashTransactionId String
  glAccountId       String
  contraAccountId   String?
  lineAmount        Decimal         @db.Decimal(15, 2)
  description       String?
  createdAt         DateTime        @default(now())
  cashTransaction   CashTransaction @relation(fields: [cashTransactionId], references: [id], onDelete: Cascade)
  contraAccount     ChartOfAccount? @relation("CashTransactionLineContraAccount", fields: [contraAccountId], references: [id])
  glAccount         ChartOfAccount  @relation("CashTransactionLineGLAccount", fields: [glAccountId], references: [id])

  @@map("cash_transaction_lines")
}

model CashTransactionPosting {
  id                String          @id @default(cuid())
  cashTransactionId String
  journalId         String
  postedAt          DateTime        @default(now())
  postedBy          String
  cashTransaction   CashTransaction @relation(fields: [cashTransactionId], references: [id])
  journal           Journal         @relation(fields: [journalId], references: [id])
  user              User            @relation(fields: [postedBy], references: [id])

  @@unique([cashTransactionId, journalId])
  @@map("cash_transaction_postings")
}

model CustomerPayment {
  id            String                   @id @default(cuid())
  paymentNo     String                   @unique
  customerId    String
  cashAccountId String
  paymentDate   DateTime
